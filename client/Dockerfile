FROM node:18 AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ENV NODE_OPTIONS="--openssl-legacy-provider"

# Build arguments for API URLs (passed from docker-compose)
ARG REACT_APP_COMMON_DATA_SERVICE_URL=http://localhost:9000
ARG REACT_APP_AUTHENTICATION_SERVICE_URL=http://localhost:7000
ARG REACT_APP_PAYMENT_SERVICE_URL=http://localhost:9050
ARG REACT_APP_SEARCH_SUGGESTION_SERVICE_URL=http://localhost:9000

# Set environment variables for the build
ENV REACT_APP_COMMON_DATA_SERVICE_URL=$REACT_APP_COMMON_DATA_SERVICE_URL
ENV REACT_APP_AUTHENTICATION_SERVICE_URL=$REACT_APP_AUTHENTICATION_SERVICE_URL
ENV REACT_APP_PAYMENT_SERVICE_URL=$REACT_APP_PAYMENT_SERVICE_URL
ENV REACT_APP_SEARCH_SUGGESTION_SERVICE_URL=$REACT_APP_SEARCH_SUGGESTION_SERVICE_URL

RUN npm run build

FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]